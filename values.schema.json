{
	"$schema": "https://json-schema.org/draft-07/schema#",
	"properties": {
		"cloud": {
			"description": "Cloud which the cluster is running on",
			"type": "object",
			"anyOf": [
				{
					"properties": {
						"provider": {
							"description": "Cloud provider",
							"type": "string",
							"enum": [
								"aws"
							]
						},
						"region": {
							"description": "Cloud region",
							"type": "string",
							"minLength": 1
						}
					}
				},
				{
					"properties": {
						"provider": {
							"description": "Cloud provider",
							"type": "string",
							"enum": [
								"azure"
							]
						}
					}
				},
				{
					"properties": {
						"provider": {
							"description": "Cloud provider",
							"type": "string",
							"enum": [
								"generic"
							]
						}
					}
				},
				{
					"properties": {
						"provider": {
							"description": "Cloud provider",
							"type": "string",
							"enum": [
								"local-rancher"
							]
						}
					}
				},
				{
					"properties": {
						"provider": {
							"description": "Cloud provider",
							"type": "string",
							"enum": [
								"local-microk8s"
							]
						}
					}
				},
				{
					"properties": {
						"provider": {
							"description": "Cloud provider",
							"type": "string",
							"enum": [
								"local-kind"
							]
						}
					}
				}
			]
		},
		"imageCredentials": {
			"description": "Docker registry credentials",
			"type": "object",
			"properties": {
				"registry": {
					"description": "URL for the registry",
					"type": "string"
				},
				"username": {
					"description": "Username for the registry",
					"type": "string"
				},
				"password": {
					"description": "Password for the registry",
					"type": "string"
				},
				"pullSecrets": {
					"description": "Existing secrets for the registry login",
					"type": "array"
				}
			},
			"anyOf": [
				{
					"required": [
						"registry",
						"username",
						"password"
					]
				},
				{
					"required": [
						"pullSecrets"
					]
				}
			]
		},
		"efs": {
			"type": "object",
			"properties": {
				"flowModules": {
					"type": "object",
					"properties": {
						"id": {
							"type": "string"
						}
					}
				},
				"functions": {
					"type": "object",
					"properties": {
						"id": {
							"type": "string"
						}
					}
				}
			}
		},
		"mfeSimulator": {
			"$ref": "#/$defs/microfrontend",
			"description": "Simulator microfrontend"
		},
		"mfeAiAgentsV2": {
			"$ref": "#/$defs/microfrontend",
			"description": "AI Agents V2 microfrontend"
		},
		"mfeInteractionPanel": {
			"$ref": "#/$defs/microfrontend",
			"description": "Interaction Panel microfrontend"
		},
		"mfeSidebar": {
			"$ref": "#/$defs/microfrontend",
			"description": "Sidebar microfrontend"
		},
		"mfeGlobalToolbar": {
			"$ref": "#/$defs/microfrontend",
			"description": "Global Toolbar microfrontend"
		},
		"mfeKnowledgeStore": {
			"$ref": "#/$defs/microfrontend",
			"description": "Knowledge Store microfrontend"
		},
		"mfeEndpoints": {
			"$ref": "#/$defs/microfrontend",
			"description": "Endpoints microfrontend"
		},
		"mfeExample": {
			"$ref": "#/$defs/microfrontend",
			"description": "Example microfrontend"
		}
	},
	"$defs": {
		"microfrontend": {
			"type": "object",
			"properties": {
				"enabled": {
					"description": "Enable or disable the microfrontend deployment",
					"type": "boolean"
				},
				"image": {
					"description": "Container image reference",
					"type": "string"
				},
				"replicaCount": {
					"description": "Number of pod replicas",
					"type": "integer",
					"minimum": 0
				},
				"resources": {
					"description": "Kubernetes resource requests and limits",
					"type": "object"
				},
				"securityContext": {
					"description": "Pod security context",
					"type": "object"
				},
				"affinity": {
					"description": "Pod affinity rules",
					"type": "object"
				},
				"nodeSelector": {
					"description": "Node selector constraints",
					"type": "object"
				},
				"tolerations": {
					"description": "Pod tolerations",
					"type": "array"
				},
				"priorityClassName": {
					"description": "Priority class name for the pod",
					"type": "string"
				}
			},
			"required": [
				"enabled",
				"image",
				"replicaCount"
			]
		}
	},
	"required": [
		"cloud",
		"imageCredentials",
		"clamd",
		"serviceAi",
		"serviceAlexaManagement",
		"serviceAnalyticsCollector",
		"serviceAnalyticsConversations",
		"serviceAnalyticsOdata",
		"serviceAnalyticsReporter",
		"serviceApi",
		"serviceAppSessionManager",
		"serviceCollector",
		"serviceCustomModules",
		"serviceEndpoint",
		"serviceExecution",
		"serviceFunctionExecution",
		"serviceFunctionScheduler",
		"serviceHandover",
		"serviceHandoverInactivity",
		"serviceHttp",
		"serviceLogs",
		"serviceNlpMatcher",
		"serviceNlpNer",
		"serviceParser",
		"servicePlaybookExecution",
		"serviceProfiles",
		"serviceResources",
		"serviceRuntimeFileManager",
		"serviceSecurity",
		"serviceSessionStateManager",
		"serviceStaticFiles",
		"serviceTaskManager",
		"serviceTrainer",
		"serviceUi",
		"serviceWebchat",
		"serviceNlpOrchestrator",
		"serviceNlpEmbeddingEn",
		"serviceNlpEmbeddingXx",
		"serviceNlpEmbeddingGe",
		"serviceNlpClassifierScoreEn",
		"serviceNlpClassifierTrainEn",
		"serviceNlpClassifierScoreGe",
		"serviceNlpClassifierTrainGe",
		"serviceNlpClassifierScoreDe",
		"serviceNlpClassifierTrainDe",
		"serviceNlpClassifierScoreJa",
		"serviceNlpClassifierTrainJa",
		"serviceNlpClassifierScoreKo",
		"serviceNlpClassifierTrainKo",
		"serviceNlpClassifierScoreXx",
		"serviceNlpClassifierTrainXx",
		"agentAssistBackend",
		"agentAssistFrontend",
		"agentAssistGenesysNotificationsForwarder"
	],
	"title": "Values",
	"type": "object"
}