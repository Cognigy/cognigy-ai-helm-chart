# Patterns to ignore when building packages.
# This supports shell glob matching, relative path matching, and
# negation (prefixed with !). Only one pattern per line.
.DS_Store
# Common VCS dirs
.git/
.gitignore
.bzr/
.bzrignore
.hg/
.hgignore
.svn/
# Common backup files
*.swp
*.bak
*.tmp
*.orig
*~
# Various IDEs
.project
.idea/
*.tmproj
.vscode/
.history
local-temp-files

# Don't package + expose CHANGELOG folder
CHANGELOG/

# Local agent / session state — must never be packaged into the chart
.claude/
.remember/
.ipynb_checkpoints/

# Repo assets + dev-only values not needed at runtime (keep release object small)
assets/
values-local.yaml
values-local.out.yaml
